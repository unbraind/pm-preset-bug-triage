{
  "name": "pm-preset-bug-triage",
  "version": "0.1.0",
  "description": "Strict bug triage pm workspace preset — production incidents, hotfixes, mandatory root-cause metadata",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unbraind/pm-preset-bug-triage.git"
  },
  "bugs": {
    "url": "https://github.com/unbraind/pm-preset-bug-triage/issues"
  },
  "homepage": "https://github.com/unbraind/pm-preset-bug-triage#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "manifest.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "audit:prod": "npm audit --omit=dev",
    "pack:dry-run": "npm pack --dry-run",
    "changelog": "pm-changelog --pm-root .agents/pm --mode prepend --output CHANGELOG.md --release-version-from-package --since-previous-tag --until-release-tag --item-url-base https://github.com/unbraind/pm-preset-bug-triage/blob/main/.agents/pm",
    "changelog:full": "pm-changelog --pm-root .agents/pm --mode replace --output CHANGELOG.md --all-release-tags --release-version-from-package --item-url-base https://github.com/unbraind/pm-preset-bug-triage/blob/main/.agents/pm",
    "changelog:check": "pm-changelog --pm-root .agents/pm --mode replace --output CHANGELOG.md --all-release-tags --release-version-from-package --item-url-base https://github.com/unbraind/pm-preset-bug-triage/blob/main/.agents/pm --check",
    "release:check": "npm run typecheck && npm run build && npm run audit:prod && npm run pack:dry-run && npm run changelog:check"
  },
  "peerDependencies": {
    "@unbrained/pm-cli": ">=2026.5.24"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@unbrained/pm-cli": "^2026.5.24",
    "pm-changelog": "^2026.5.25",
    "@types/node": "^25.9.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "@unbraind",
  "license": "MIT",
  "keywords": [
    "bug",
    "pm-cli",
    "pm-package",
    "pm-preset",
    "preset",
    "triage"
  ],
  "pm": {
    "aliases": [
      "bug-triage"
    ],
    "extensions": [
      "."
    ],
    "catalog": {
      "display_name": "Bug Triage Preset",
      "category": "preset",
      "summary": "Strict bug triage pm workspace preset — production incidents, hotfixes, mandatory root-cause metadata",
      "tags": [
        "preset",
        "bugs",
        "incidents"
      ],
      "links": {
        "docs": "https://github.com/unbraind/pm-preset-bug-triage#readme",
        "npm": "https://www.npmjs.com/package/pm-preset-bug-triage",
        "repository": "https://github.com/unbraind/pm-preset-bug-triage",
        "report": "https://github.com/unbraind/pm-preset-bug-triage/issues"
      }
    },
    "docs": [
      "README.md",
      "CHANGELOG.md"
    ],
    "examples": [
      "README.md"
    ]
  }
}
